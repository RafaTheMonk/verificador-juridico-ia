# Chave pública do Datajud (CNJ) — fornecida pelo próprio órgão em datajud-wiki.cnj.jus.br
# Esta é a chave documentada; se mudar, atualize aqui.
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==

# Gemini (Google AI Studio) - opcional. Se ausente, o sistema usa apenas a camada de regras.
GEMINI_API_KEY=

# Toggle para a camada 3 (adequação contextual via LLM)
# true  = executa as duas passagens do Gemini
# false = usa apenas a heurística baseada em regras (custo zero)
USE_LLM_ADEQUACY=false

# Timeout (ms) para chamadas externas
HTTP_TIMEOUT_MS=15000

# Porta para o servidor local
PORT=3000

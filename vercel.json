{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/verificar.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/verificar", "destination": "/api/verificar" },
    { "source": "/health",    "destination": "/api/health" }
  ]
}
